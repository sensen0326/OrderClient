.index-search {
  margin: 0 30rpx;
  -webkit-transform: translateY(-40rpx);
          transform: translateY(-40rpx);
}
.index-search__bar {
  display: flex;
  align-items: center;
  background: #f6f7fb;
  border-radius: 60rpx;
  padding: 0 20rpx;
  height: 70rpx;
}
.index-search__input {
  flex: 1;
  margin: 0 12rpx;
  font-size: 26rpx;
  border: none;
  background: transparent;
  outline: none;
}
.index-search__action {
  font-size: 26rpx;
  color: #ee2f37;
}
.index-recommend {
  margin: 20rpx 30rpx;
  padding: 20rpx;
  background: #fff7f5;
  border-radius: 20rpx;
}
.index-recommend__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.index-recommend__title {
  font-size: 30rpx;
  font-weight: bold;
}
.index-recommend__more {
  font-size: 24rpx;
  color: #ee2f37;
}
.index-recommend scroll-view {
  white-space: nowrap;
}
.index-recommend__item {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}
.index-recommend__item image {
  width: 180rpx;
  height: 150rpx;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}
.index-recommend__name {
  font-size: 26rpx;
  font-weight: 600;
}
.index-recommend__price {
  color: #ee2f37;
  font-weight: bold;
  margin-top: 6rpx;
}
.body {
  position: relative;
  z-index: 1;
  margin: -40rpx 30rpx 0 30rpx;
  padding: 0 15rpx;
  background-color: #fff;
  border-radius: 14rpx;
}
.body__text {
  font-weight: bold;
  font-size: 30rpx;
  margin-top: 15rpx;
}
.integral {
  display: flex;
  align-items: flex-end;
  padding: 20rpx;
}
.integral__nav {
  color: #303133;
  font-weight: bold;
  margin-bottom: 20rpx;
  font-size: 30rpx;
}
.integral__nav text {
  font-size: 38rpx;
}
.integral__desc {
  font-size: 24rpx;
  color: #909399;
  margin-bottom: 10rpx;
}
.grid-text {
  font-size: 38rpx;
  font-weight: bold;
}
.grid-desc {
  font-size: 24rpx;
  color: #909399;
  margin-bottom: 30rpx;
}
.table-popup {
  width: 600rpx;
  padding: 48rpx 36rpx 40rpx;
  text-align: center;
  background: #ffffff;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.12);
}
.table-popup__welcome {
  font-size: 32rpx;
  color: #3a3a3a;
  margin-bottom: 12rpx;
  font-weight: 600;
}
.table-popup__table {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.table-popup__table-no {
  color: #000;
  font-weight: 700;
}
.table-popup__subtitle {
  font-size: 26rpx;
  color: #9b9b9b;
  margin-bottom: 24rpx;
}
.table-popup__people-title {
  font-size: 26rpx;
  color: #3a3a3a;
  margin-bottom: 18rpx;
  font-weight: 600;
}
.table-popup__people-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx 12rpx;
  margin-bottom: 32rpx;
}
.table-popup__people-btn {
  width: 128rpx;
  height: 72rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e6e6e6;
  color: #4a4a4a;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  transition: all 0.2s ease;
}
.table-popup__people-btn.is-active {
  border-color: #5c9bfd;
  background: #e8f0ff;
  color: #2f75ff;
  box-shadow: 0 8rpx 20rpx rgba(47, 117, 255, 0.18);
}
.table-popup__confirm {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(90deg, #7ab6ff 0%, #5b96ff 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

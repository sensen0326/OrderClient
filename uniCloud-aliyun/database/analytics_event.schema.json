{
	"bsonType": "object",
	"required": ["event"],
	"permission": {
		"read": true,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "事件 ID"
		},
		"event": {
			"bsonType": "string",
			"description": "事件名称"
		},
		"user_id": {
			"bsonType": "string",
			"description": "用户 ID"
		},
		"data": {
			"bsonType": "object",
			"description": "额外参数"
		},
		"client_info": {
			"bsonType": "object",
			"description": "客户端信息"
		},
		"created_at": {
			"bsonType": "long",
			"description": "记录时间",
			"defaultValue": {
				"$env": "now"
			}
		}
	}
}

{
	"bsonType": "object",
	"required": ["ticket_no", "sender_type", "content"],
	"permission": {
		"read": true,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "消息 ID"
		},
		"ticket_no": {
			"bsonType": "string",
			"description": "所属工单号"
		},
		"sender_type": {
			"bsonType": "string",
			"description": "发送者 user/staff/system"
		},
		"content": {
			"bsonType": "string",
			"description": "内容文本"
		},
		"attachments": {
			"bsonType": "array",
			"description": "附件列表",
			"items": {
				"bsonType": "string"
			}
		},
		"created_at": {
			"bsonType": "long",
			"description": "发送时间",
			"defaultValue": {
				"$env": "now"
			}
		}
	}
}

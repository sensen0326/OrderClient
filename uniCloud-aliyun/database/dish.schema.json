{
	"bsonType": "object",
	"required": ["name", "category_id", "skus", "restaurant_scope", "status"],
	"permission": {
		"read": true,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "菜品 ID"
		},
		"name": {
			"bsonType": "string",
			"description": "菜品名称"
		},
		"category_id": {
			"bsonType": "string",
			"description": "所属分类 ID"
		},
		"cover": {
			"bsonType": "string",
			"description": "主图"
		},
		"description": {
			"bsonType": "string",
			"description": "菜品描述"
		},
		"tags": {
			"bsonType": "array",
			"description": "标签（热销\/新品\/推荐等）",
			"items": {
				"bsonType": "string"
			}
		},
		"recommend_weight": {
			"bsonType": "int",
			"description": "推荐权重"
		},
		"status": {
			"bsonType": "int",
			"description": "状态（1=上架，0=下架）",
			"defaultValue": 1
		},
		"restaurant_scope": {
			"bsonType": "string",
			"description": "适用门店"
		},
		"skus": {
			"bsonType": "array",
			"description": "规格列表",
			"items": {
				"bsonType": "object",
				"required": ["sku_id", "name", "price"],
				"properties": {
					"sku_id": {
						"bsonType": "string"
					},
					"name": {
						"bsonType": "string"
					},
					"price": {
						"bsonType": "double"
					},
					"origin_price": {
						"bsonType": "double"
					},
					"package_fee": {
						"bsonType": "double"
					},
					"stock": {
						"bsonType": "int"
					},
					"min_purchase": {
						"bsonType": "int"
					},
					"max_purchase": {
						"bsonType": "int"
					}
				}
			}
		},
		"option_groups": {
			"bsonType": "array",
			"description": "可选项分组（口味、加料等）",
			"items": {
				"bsonType": "object",
				"required": ["group_id", "name", "type", "options"],
				"properties": {
					"group_id": {
						"bsonType": "string"
					},
					"name": {
						"bsonType": "string"
					},
					"type": {
						"bsonType": "string",
						"enum": ["single", "multi"]
					},
					"required": {
						"bsonType": "bool"
					},
					"options": {
						"bsonType": "array",
						"items": {
							"bsonType": "object",
							"required": ["option_id", "name"],
							"properties": {
								"option_id": {
									"bsonType": "string"
								},
								"name": {
									"bsonType": "string"
								},
								"price": {
									"bsonType": "double"
								}
							}
						}
					}
				}
			}
		},
		"keywords": {
			"bsonType": "array",
			"description": "搜索关键词",
			"items": {
				"bsonType": "string"
			}
		},
		"created_at": {
			"bsonType": "long",
			"description": "创建时间",
			"defaultValue": {
				"$env": "now"
			}
		},
		"updated_at": {
			"bsonType": "long",
			"description": "最后更新时间",
			"defaultValue": {
				"$env": "now"
			}
		}
	}
}
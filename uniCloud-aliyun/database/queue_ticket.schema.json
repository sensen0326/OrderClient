{
  "bsonType": "object",
  "description": "排队取号/预约记录",
  "required": [
    "ticket_no",
    "party_size",
    "status",
    "created_at"
  ],
  "permission": {
    "read": true,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "记录 ID"
    },
    "ticket_no": {
      "bsonType": "string",
      "description": "叫号，唯一"
    },
    "party_size": {
      "bsonType": "int",
      "description": "就餐人数"
    },
    "status": {
      "bsonType": "string",
      "description": "waiting/called/seated/cancelled/reserved"
    },
    "contact": {
      "bsonType": "string",
      "description": "联系电话或微信"
    },
    "notify_channel": {
      "bsonType": "string",
      "description": "通知方式"
    },
    "estimated_wait": {
      "bsonType": "int",
      "description": "预计等待分钟"
    },
    "arrive_time": {
      "bsonType": "string",
      "description": "预约到店时间"
    },
    "note": {
      "bsonType": "string",
      "description": "备注"
    },
    "created_at": {
      "bsonType": "double",
      "description": "创建时间"
    },
    "updated_at": {
      "bsonType": "double",
      "description": "更新时间"
    }
  }
}

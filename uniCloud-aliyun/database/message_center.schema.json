{
	"bsonType": "object",
	"required": ["user_id", "title", "content"],
	"permission": {
		"read": true,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "消息 ID"
		},
		"user_id": {
			"bsonType": "string",
			"description": "接收用户 ID"
		},
		"type": {
			"bsonType": "string",
			"description": "消息类型 order/promotion/system"
		},
		"title": {
			"bsonType": "string",
			"description": "标题"
		},
		"content": {
			"bsonType": "string",
			"description": "内容"
		},
		"link": {
			"bsonType": "string",
			"description": "跳转链接或关联 ID"
		},
		"is_read": {
			"bsonType": "bool",
			"description": "是否已读",
			"defaultValue": false
		},
		"created_at": {
			"bsonType": "long",
			"description": "创建时间",
			"defaultValue": {
				"$env": "now"
			}
		},
		"read_at": {
			"bsonType": "long",
			"description": "阅读时间"
		}
	}
}

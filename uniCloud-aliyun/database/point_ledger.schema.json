{
  "bsonType": "object",
  "description": "积分流水",
  "required": [
    "user_id",
    "change",
    "balance",
    "event",
    "created_at"
  ],
  "permission": {
    "read": true,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "记录 ID"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户 ID"
    },
    "change": {
      "bsonType": "int",
      "description": "积分变动"
    },
    "balance": {
      "bsonType": "int",
      "description": "变动后的积分"
    },
    "event": {
      "bsonType": "string",
      "description": "事件标识，如 daily_sign/order/兑换 等"
    },
    "remark": {
      "bsonType": "string",
      "description": "备注"
    },
    "order_no": {
      "bsonType": "string",
      "description": "关联订单"
    },
    "created_at": {
      "bsonType": "double",
      "description": "创建时间"
    }
  }
}

{
  "bsonType": "object",
  "required": [
    "event",
    "name",
    "calc_type",
    "status"
  ],
  "properties": {
    "_id": {
      "description": "规则 ID"
    },
    "event": {
      "bsonType": "string",
      "description": "事件标识，daily_sign/order_pay 等"
    },
    "name": {
      "bsonType": "string",
      "description": "规则名称"
    },
    "calc_type": {
      "bsonType": "string",
      "enum": [
        "fixed",
        "ratio"
      ],
      "description": "积分计算方式：固定值或按比例"
    },
    "value": {
      "bsonType": "int",
      "description": "calc_type=fixed 时的积分值"
    },
    "ratio": {
      "bsonType": "double",
      "description": "calc_type=ratio 时的积分系数（每单位金额积分）"
    },
    "max_points": {
      "bsonType": "int",
      "description": "单次可获得的最大积分"
    },
    "change_direction": {
      "bsonType": "string",
      "enum": [
        "increase",
        "decrease"
      ],
      "description": "积分增减方向"
    },
    "limit": {
      "bsonType": "int",
      "description": "周期内触发上限，0 为不限"
    },
    "limit_period": {
      "bsonType": "string",
      "enum": [
        "day",
        "total",
        "none"
      ],
      "description": "限制周期：按天、终身或不限"
    },
    "limit_tip": {
      "bsonType": "string",
      "description": "达到上限后的提示语"
    },
    "description": {
      "bsonType": "string",
      "description": "规则描述/权益说明"
    },
    "status": {
      "bsonType": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "description": "规则状态"
    },
    "created_at": {
      "bsonType": "long"
    },
    "updated_at": {
      "bsonType": "long"
    }
  },
  "permission": {
    "read": true,
    "create": false,
    "update": false,
    "delete": false
  }
}

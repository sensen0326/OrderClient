{
	"bsonType": "object",
	"required": ["order_no", "user_id", "rating_taste", "rating_env", "rating_service"],
	"permission": {
		"read": true,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "评价 ID"
		},
		"order_no": {
			"bsonType": "string",
			"description": "订单号"
		},
		"user_id": {
			"bsonType": "string",
			"description": "用户 ID"
		},
		"nickname": {
			"bsonType": "string",
			"description": "用户昵称快照"
		},
		"avatar": {
			"bsonType": "string",
			"description": "用户头像快照"
		},
		"rating_taste": {
			"bsonType": "int",
			"description": "口味评分 1-5",
			"maximum": 5,
			"minimum": 1
		},
		"rating_env": {
			"bsonType": "int",
			"description": "环境评分 1-5",
			"maximum": 5,
			"minimum": 1
		},
		"rating_service": {
			"bsonType": "int",
			"description": "服务评分 1-5",
			"maximum": 5,
			"minimum": 1
		},
		"content": {
			"bsonType": "string",
			"description": "评价内容"
		},
		"is_anonymous": {
			"bsonType": "bool",
			"description": "是否匿名"
		},
		"dish_ids": {
			"bsonType": "array",
			"description": "涉及菜品 ID",
			"items": {
				"bsonType": "string"
			}
		},
		"status": {
			"bsonType": "string",
			"description": "审核状态 pending/approved/refused",
			"defaultValue": "pending"
		},
		"created_at": {
			"bsonType": "long",
			"description": "创建时间",
			"defaultValue": {
				"$env": "now"
			}
		},
		"updated_at": {
			"bsonType": "long",
			"description": "更新时间",
			"defaultValue": {
				"$env": "now"
			}
		}
	}
}

{
  "bsonType": "object",
  "description": "配送范围与费用规则",
  "required": [
    "name",
    "type",
    "config"
  ],
  "permission": {
    "read": true,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "记录 ID"
    },
    "name": {
      "bsonType": "string",
      "description": "范围名称"
    },
    "type": {
      "bsonType": "string",
      "description": "circle/polygon"
    },
    "config": {
      "bsonType": "object",
      "description": "范围配置（半径或经纬度）"
    },
    "min_amount": {
      "bsonType": "double",
      "description": "起送价"
    },
    "delivery_fee": {
      "bsonType": "double",
      "description": "基础配送费"
    },
    "package_fee": {
      "bsonType": "double",
      "description": "打包费"
    },
    "extra_rules": {
      "bsonType": "array",
      "description": "距离阶梯",
      "items": {
        "bsonType": "object",
        "properties": {
          "distance": {
            "bsonType": "double",
            "description": "距离上限 km"
          },
          "delivery_fee": {
            "bsonType": "double",
            "description": "该距离的配送费"
          }
        }
      }
    },
    "updated_at": {
      "bsonType": "double",
      "description": "更新时间"
    }
  }
}

{
  "bsonType": "object",
  "required": [
    "user_id",
    "goods_id",
    "goods_name",
    "cost_points",
    "status",
    "created_at"
  ],
  "properties": {
    "_id": {
      "description": "订单 ID"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户 ID"
    },
    "goods_id": {
      "bsonType": "string",
      "description": "积分商品 ID"
    },
    "goods_name": {
      "bsonType": "string",
      "description": "积分商品名称"
    },
    "goods_cover": {
      "bsonType": "string",
      "description": "展示图片"
    },
    "delivery_type": {
      "bsonType": "string",
      "description": "领取方式 self_pick/delivery",
      "default": "self_pick"
    },
    "contact": {
      "bsonType": "string",
      "description": "联系人信息"
    },
    "address": {
      "bsonType": "string",
      "description": "配送地址"
    },
    "remark": {
      "bsonType": "string",
      "description": "备注"
    },
    "cost_points": {
      "bsonType": "int",
      "description": "消耗积分"
    },
    "status": {
      "bsonType": "string",
      "enum": [
        "pending",
        "processing",
        "completed",
        "cancelled"
      ],
      "description": "处理状态"
    },
    "created_at": {
      "bsonType": "long",
      "description": "创建时间"
    },
    "updated_at": {
      "bsonType": "long",
      "description": "更新时间"
    }
  },
  "permission": {
    "read": true,
    "create": false,
    "update": false,
    "delete": false
  }
}
